<%# locals: (done: false, current: false, label:, detail:) %>
<div class="row" style="gap:10px">
  <div style="
    width:18px;height:18px;border-radius:50%;
    <%= 'background:var(--pos);' if done %>
    <%= 'background:var(--accent);' if current %>
    <%= 'border:1px dashed var(--line-2);' unless done || current %>
    color:white;display:flex;align-items:center;justify-content:center;flex-shrink:0">
    <% if done %>
      <%= icon :check, size: 11, stroke: 3 %>
    <% elsif current %>
      <span class="dot-pulse" style="width:6px;height:6px;border-radius:50%;background:white"></span>
    <% end %>
  </div>
  <div style="flex:1">
    <div style="font-size:13px;font-weight:500;color: <%= done ? 'var(--ink-2)' : 'var(--ink)' %>"><%= label %></div>
    <div class="mono" style="font-size:10px;color:var(--ink-3)"><%= detail %></div>
  </div>
  <% if done %>
    <span class="mono" style="font-size:10px;color:var(--ink-3)">0.<%= rand(1..9) %>s</span>
  <% end %>
</div>
