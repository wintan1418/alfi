<%# locals: (product:, copy:) %>
<div style="background:white;padding:12px;border-radius:8px;border:1px solid #eee;font-family:-apple-system,system-ui">
  <div class="row" style="gap:10px;margin-bottom:8px">
    <div style="width:32px;height:32px;border-radius:50%;background:#000;color:white;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700">α</div>
    <div style="flex:1">
      <div class="row" style="gap:4px">
        <span style="font-size:12px;font-weight:700;color:#000">alfi finds</span>
        <span style="font-size:11px;color:#71767b">@alfifinds · 1m</span>
      </div>
    </div>
  </div>
  <div style="font-size:12px;color:#000;white-space:pre-wrap;line-height:1.4;margin-bottom:8px"><%= copy %></div>
  <% if product.display_image_url.present? %>
    <img src="<%= product.display_image_url %>" alt=""
         style="width:100%;height:60px;object-fit:cover;border-radius:8px;margin-bottom:8px">
  <% else %>
    <div class="ph-img" style="height:60px;border-radius:8px;margin-bottom:8px">photo</div>
  <% end %>
  <div class="row" style="gap:16px;color:#71767b;font-size:10px">
    <span>💬 14</span><span>🔁 28</span><span>♡ 192</span><span>📊 4.2k</span>
  </div>
</div>
