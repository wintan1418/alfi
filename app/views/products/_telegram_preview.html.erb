<%# locals: (product:, copy:, cta:) %>
<div style="background:oklch(0.97 0.01 235);border-radius:8px;padding:10px;font-family:-apple-system,system-ui,sans-serif">
  <div class="row" style="gap:8px;margin-bottom:8px">
    <div style="width:28px;height:28px;border-radius:50%;background:oklch(0.62 0.13 235);color:white;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600">α</div>
    <div>
      <div style="font-size:12px;font-weight:600;color:#000">Alfi Finds</div>
      <div style="font-size:10px;color:#666">14.2k subscribers</div>
    </div>
  </div>
  <% if product.display_image_url.present? %>
    <img src="<%= product.display_image_url %>" alt=""
         style="width:100%;height:70px;object-fit:cover;border-radius:6px;margin-bottom:6px">
  <% else %>
    <div class="ph-img" style="height:70px;border-radius:6px;margin-bottom:6px">photo</div>
  <% end %>
  <div style="font-size:11.5px;color:#000;white-space:pre-wrap;line-height:1.45;max-height:120px;overflow:hidden"><%= copy %></div>
  <% if cta.present? %>
    <div style="margin-top:8px;padding:6px 10px;background:oklch(0.62 0.13 235);color:white;border-radius:4px;font-size:11px;text-align:center;font-weight:500">
      🔗 <%= cta %>
    </div>
  <% end %>
</div>
