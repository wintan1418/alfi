<% content_for :active_nav, "settings" %>
<% content_for :title, "Settings" %>
<% @crumbs = ["alfi", "Settings"] %>

<div class="page-wide">
  <h1 class="section-h" style="margin-bottom:6px">Settings</h1>
  <div class="section-sub" style="margin-bottom:28px">Operator-level. Workspace-wide. No multi-tenant.</div>

  <% if flash[:notice] %>
    <div class="card" style="padding:10px 14px;background:var(--pos-bg);color:var(--pos);font-size:12px;margin-bottom:16px;border-color:transparent">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <%# Channels %>
  <div style="margin-bottom:36px;display:grid;grid-template-columns:240px 1fr;gap:32px">
    <div>
      <h3 class="serif" style="font-size:22px;font-style:normal;margin:0 0 4px">Channels</h3>
      <div style="font-size:12px;color:var(--ink-3)">Connected publishing destinations</div>
    </div>
    <div>
      <% @channels.each_with_index do |c, i| %>
        <%
          short_key = { "telegram"=>"tg", "pinterest"=>"pin", "x"=>"x", "tiktok"=>"tt", "instagram"=>"ig" }[c.platform.to_s]
          status_label = c.credentials_valid? && c.active ? "Live" : (c.platform.to_s.in?(%w[tiktok instagram]) ? c.platform.to_s == "tiktok" ? "Assist" : "Paused" : "Setup")
          tag_class = case status_label
                      when "Live" then "live"
                      when "Assist" then "flagged"
                      else "warn"
                      end
        %>
        <div class="row" style="padding:14px 0;gap:14px;<%= 'border-bottom:1px solid var(--line)' unless i == @channels.size - 1 %>">
          <div style="width:32px;height:32px;border-radius:6px;background:var(--<%= short_key %>);display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:13px;font-family:var(--font-mono)">
            <%= c.platform.to_s[0].upcase %>
          </div>
          <div style="flex:1">
            <div class="row" style="gap:8px">
              <span style="font-size:14px;color:var(--ink);font-weight:600"><%= c.platform.to_s.titleize %></span>
              <span class="tag <%= tag_class %>"><% if status_label == "Live" %><span class="dot"></span><% end %><%= status_label %></span>
            </div>
            <div class="mono" style="font-size:11px;color:var(--ink-3);margin-top:3px">
              <%= c.handle.presence || "no handle set" %>
            </div>
          </div>
          <%= link_to "Configure", edit_channel_account_path(c), class: "btn sm ghost" %>
        </div>
      <% end %>
    </div>
  </div>

  <%# Domain %>
  <div style="margin-bottom:36px;display:grid;grid-template-columns:240px 1fr;gap:32px">
    <div>
      <h3 class="serif" style="font-size:22px;font-style:normal;margin:0 0 4px">Domain & short links</h3>
      <div style="font-size:12px;color:var(--ink-3)">Used for tracked redirects</div>
    </div>
    <div>
      <% domain = ENV["SHORT_LINK_HOST"].presence || "http://localhost:3000" %>
      <div class="card" style="padding:16px;background:var(--bg-2)">
        <div class="spread" style="margin-bottom:8px">
          <span class="mono" style="font-size:14px;color:var(--ink);font-weight:600"><%= domain.sub(%r{^https?://}, '') %></span>
          <% if ENV["SHORT_LINK_HOST"].present? %>
            <span class="tag live"><span class="dot"></span>Verified</span>
          <% else %>
            <span class="tag flagged">Local only</span>
          <% end %>
        </div>
        <div style="font-size:12px;color:var(--ink-3);line-height:1.6">
          Set <code class="mono">SHORT_LINK_HOST</code> in env when you have a domain.<br>
          Pinterest verification: <span class="mono"><%= ENV["PINTEREST_APP_ID"].present? ? "configured in env" : "—" %></span><br>
          R2 image hosting: <span class="mono"><%= Alfi::Live.r2? ? "active" : "local disk (dev)" %></span>
        </div>
      </div>
    </div>
  </div>

  <%# Prompts %>
  <div style="margin-bottom:36px;display:grid;grid-template-columns:240px 1fr;gap:32px">
    <div>
      <h3 class="serif" style="font-size:22px;font-style:normal;margin:0 0 4px">AI prompts</h3>
      <div style="font-size:12px;color:var(--ink-3)">Versioned. Every angle records the prompt that wrote it.</div>
    </div>
    <div>
      <%
        prompts_versions = [
          { v: "v3.2", label: "Practical · platform-aware", when_at: "Apr 14", active: true,  perf: "EPC: $0.79" },
          { v: "v3.2", label: "Premium · platform-aware",   when_at: "Apr 14", active: true,  perf: "EPC: $0.71" },
          { v: "v3.2", label: "Witty · platform-aware",     when_at: "Apr 14", active: true,  perf: "EPC: $0.92" },
          { v: "v2.0", label: "Practical (legacy)",         when_at: "Mar 02", active: false, perf: "EPC: $0.61" }
        ]
      %>
      <% prompts_versions.each do |p| %>
        <div class="row" style="padding:10px 0;gap:12px;border-bottom:1px solid var(--line)">
          <span class="mono" style="font-size:11px;padding:2px 6px;background: <%= p[:active] ? 'var(--accent-bg)' : 'var(--bg-3)' %>;color: <%= p[:active] ? 'var(--accent-fg)' : 'var(--ink-3)' %>;border-radius:4px;min-width:36px;text-align:center"><%= p[:v] %></span>
          <span style="flex:1;color:var(--ink);font-size:13px"><%= p[:label] %></span>
          <span class="mono" style="font-size:11px;color:var(--ink-3)"><%= p[:perf] %></span>
          <span class="mono" style="font-size:11px;color:var(--ink-3)"><%= p[:when_at] %></span>
          <% if p[:active] %>
            <span class="tag live"><span class="dot"></span>Active</span>
          <% else %>
            <%= link_to "Diff", prompts_path, class: "btn sm ghost" %>
          <% end %>
        </div>
      <% end %>
      <%= link_to prompts_path, class: "btn sm", style: "margin-top:12px" do %>
        <%= icon :sparkle, size: 11 %> Open prompt library
      <% end %>
    </div>
  </div>

  <%# Discovery toggles — REAL persisted Setting records %>
  <div style="margin-bottom:36px;display:grid;grid-template-columns:240px 1fr;gap:32px">
    <div>
      <h3 class="serif" style="font-size:22px;font-style:normal;margin:0 0 4px">Discovery</h3>
      <div style="font-size:12px;color:var(--ink-3)">Auto-pull from Temu Hot Items</div>
    </div>
    <div>
      <% [
          { key: "discovery.daily_sync",    label: "Daily Hot Items sync",            sub: "Runs at 06:00 · 12 products / day · via Apify (when token set)" },
          { key: "discovery.auto_generate", label: "Auto-generate angles on import",  sub: "Skips manual queue · only if score ≥ 75" },
          { key: "discovery.auto_schedule", label: "Auto-schedule top-scoring products", sub: "Posts to all live channels at optimal times" }
        ].each do |t| %>
        <% on = @toggles[t[:key]] %>
        <%= button_to settings_path(toggle: t[:key]), method: :patch,
              class: "row",
              form: { style: "padding:12px 0;gap:14px;width:100%;border-bottom:1px solid var(--line);" },
              style: "background:transparent;border:none;cursor:pointer;text-align:left;flex:1;display:flex;align-items:center;gap:14px;width:100%" do %>
          <div style="flex:1">
            <div style="font-size:13px;color:var(--ink);font-weight:500"><%= t[:label] %></div>
            <div class="mono" style="font-size:11px;color:var(--ink-3)"><%= t[:sub] %></div>
          </div>
          <div style="
            width:32px;height:18px;border-radius:10px;
            background: <%= on ? 'var(--accent)' : 'var(--bg-3)' %>;
            border:1px solid var(--line);
            position:relative;flex-shrink:0">
            <div style="
              width:14px;height:14px;border-radius:50%;background:white;
              position:absolute;top:1px;left: <%= on ? '16px' : '1px' %>;
              box-shadow:0 1px 2px rgba(0,0,0,0.2);transition:left 0.15s"></div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
</div>
