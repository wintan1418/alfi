<% content_for :active_nav, "links" %>
<% content_for :title, "New short link" %>
<% @crumbs = ["alfi", "Workshop", "Short links", "New"] %>

<div class="page-narrow">
  <%= link_to links_path, class: "btn ghost sm", style: "margin-bottom:16px" do %>
    <%= icon :chev, size: 11, style: "transform:rotate(180deg)" %> Back to links
  <% end %>

  <div class="eyebrow" style="margin-bottom:6px">Short link</div>
  <h1 class="section-h" style="margin-bottom:6px">Make a tracked URL.</h1>
  <div class="section-sub" style="margin-bottom:24px">
    Pick a product (we'll grab its affiliate URL) or paste any destination directly. Slug auto-generates if you leave it blank.
  </div>

  <%= form_with model: @link, url: links_path, class: "card", style: "padding:20px;display:flex;flex-direction:column;gap:16px" do |f| %>
    <% if @link.errors.any? %>
      <div style="padding:10px;background:var(--neg-bg);color:var(--neg);border-radius:6px;font-size:12px">
        <%= @link.errors.full_messages.to_sentence %>
      </div>
    <% end %>

    <div class="col" style="gap:6px">
      <label class="eyebrow">Linked product (optional)</label>
      <select name="product_id" class="input mono">
        <option value="">— none / external destination —</option>
        <% @products.each do |p| %>
          <option value="<%= p.id %>"><%= p.legacy_id %> · <%= truncate(p.title, length: 50) %></option>
        <% end %>
      </select>
      <div class="mono" style="font-size:11px;color:var(--ink-3)">
        Picking a product auto-fills the destination from its affiliate URL.
      </div>
    </div>

    <div class="col" style="gap:6px">
      <label class="eyebrow">Destination URL</label>
      <%= f.text_field :destination_url, class: "input mono",
            placeholder: "https://temu.com/...?aff=alfi" %>
      <div class="mono" style="font-size:11px;color:var(--ink-3)">
        Required if you didn't pick a product. The browser is redirected here on click.
      </div>
    </div>

    <div class="col" style="gap:6px">
      <label class="eyebrow">Slug (optional)</label>
      <div class="row" style="gap:6px">
        <span class="mono" style="font-size:13px;color:var(--ink-3);padding:8px 0">alfi.co/</span>
        <%= f.text_field :slug, class: "input mono", placeholder: "leave blank for auto", style: "flex:1" %>
      </div>
      <div class="mono" style="font-size:11px;color:var(--ink-3)">
        Lowercase letters/digits/hyphens. We auto-generate a 7-char slug if you leave it blank.
      </div>
    </div>

    <div class="row" style="gap:10px;margin-top:8px">
      <%= f.submit "Create short link", class: "btn accent",
            style: "padding:10px 18px;font-weight:600" %>
      <%= link_to "Cancel", links_path, class: "btn ghost" %>
    </div>
  <% end %>
</div>
