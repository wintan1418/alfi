<% content_for :active_nav, "links" %>
<% content_for :title, "Short links" %>
<% @crumbs = ["alfi", "Workshop", "Short links"] %>

<div class="page">
  <div class="spread" style="margin-bottom:20px">
    <div>
      <h1 class="section-h">Short links</h1>
      <div class="section-sub">
        Every (product × angle × channel) gets its own tracked URL · domain
        <span class="mono"><%= ENV["SHORT_LINK_HOST"]&.sub(%r{^https?://}, "") || "alfi.co" %></span>
      </div>
    </div>
    <div class="row" style="gap:8px">
      <button class="btn"><%= icon :upload, size: 13 %> Export</button>
      <%= link_to new_link_path, class: "btn accent" do %>
        <%= icon :plus, size: 13, stroke: 2.2 %> New link
      <% end %>
    </div>
  </div>

  <% if flash[:notice] %>
    <div class="card" style="padding:10px 14px;background:var(--pos-bg);color:var(--pos);font-size:12px;margin-bottom:16px;border-color:transparent">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <div class="kpi-row" style="margin-bottom:20px">
    <div class="kpi">
      <div class="kpi-label">Active links</div>
      <div class="kpi-value"><%= @kpi_active %></div>
      <div class="kpi-delta up"><%= @kpi_active.zero? ? "create your first" : "tracked redirects" %></div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Clicks · 30d</div>
      <div class="kpi-value"><%= mono_n @kpi_clicks %></div>
      <div class="kpi-delta up">human-only</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Top EPC</div>
      <div class="kpi-value"><span class="unit">$</span>0.92</div>
      <div class="kpi-delta">witty · TG</div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Bot traffic blocked</div>
      <div class="kpi-value"><%= mono_n @kpi_blocked %></div>
      <div class="kpi-delta">filtered out</div>
    </div>
  </div>

  <div class="card" style="padding:0">
    <div class="card-head">
      <div class="card-title">All tracked links</div>
      <span class="card-sub" style="margin-left:8px">sorted by clicks</span>
      <div style="flex:1"></div>
      <span class="mono" style="font-size:11px;color:var(--ink-3)"><%= @links.count %> links</span>
    </div>

    <% if @links.empty? %>
      <div style="padding:32px;text-align:center;color:var(--ink-3)">
        <div class="eyebrow" style="margin-bottom:8px">No short links yet</div>
        <div style="font-size:13px">
          <%= link_to "Create the first one", new_link_path, style: "color:var(--accent-fg)" %>
          or it'll get auto-generated when you ship a post.
        </div>
      </div>
    <% else %>
      <table class="tbl">
        <thead>
          <tr>
            <th>Slug</th>
            <th>Destination</th>
            <th class="r">Clicks</th>
            <th class="r">Last clicked</th>
            <th>Status</th>
            <th style="width:100px"></th>
          </tr>
        </thead>
        <tbody>
          <% @links.each do |l| %>
            <%
              live = l.click_count > 0 || l.created_at && l.created_at > 7.days.ago
              hot = l.click_count > 200
            %>
            <tr>
              <td>
                <div class="row" style="gap:6px">
                  <span class="mono" style="font-size:11px;color:var(--ink-3)">alfi.co/</span>
                  <span class="mono" style="font-size:12px;font-weight:600;background:var(--accent-bg);color:var(--accent-fg);padding:1px 5px;border-radius:3px"><%= l.slug %></span>
                  <% if hot %><%= icon :bolt, size: 10, stroke: 2.2, style: "color:var(--accent)" %><% end %>
                </div>
              </td>
              <td style="font-size:12px;color:var(--ink-2);max-width:340px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                <%= truncate(l.destination_url, length: 56) %>
              </td>
              <td class="num r" style="color:var(--ink)"><%= mono_n l.click_count %></td>
              <td class="num r" style="color:var(--ink-3);font-size:11px">
                <%= l.last_clicked_at ? time_ago_in_words(l.last_clicked_at) + " ago" : "—" %>
              </td>
              <td><%= live ? status_tag(:live) : status_tag(:draft) %></td>
              <td>
                <div class="row" style="gap:4px;justify-content:flex-end">
                  <a href="/r/<%= l.slug %>" target="_blank" class="btn sm ghost" style="padding:3px 6px" title="Open redirect">
                    <%= icon :link, size: 11 %>
                  </a>
                  <button class="btn sm ghost" style="padding:3px 6px" title="Analytics">
                    <%= icon :chart, size: 11 %>
                  </button>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>
