<% content_for :active_nav, "earnings" %>
<% content_for :title, "Earnings" %>
<% @crumbs = ["alfi", "Earnings"] %>

<div class="page">
  <div class="spread" style="margin-bottom:20px">
    <div>
      <h1 class="section-h">Earnings & reconciliation</h1>
      <div class="section-sub">Match Temu's monthly CSV against your tracked clicks. Catch the orphans.</div>
    </div>
    <div class="row" style="gap:8px">
      <%= form_with url: import_earnings_path, multipart: true, class: "row", style: "gap:8px" do |f| %>
        <%= f.text_field :period, value: Date.current.strftime("%Y-%m"),
              class: "input mono", style: "width:110px;padding:6px 10px",
              placeholder: "2026-04", pattern: "\\d{4}-\\d{2}", required: true %>
        <%= f.file_field :csv_file, accept: ".csv", required: true,
              class: "btn", style: "padding:5px 10px;font-size:12px" %>
        <%= f.submit "Upload CSV", class: "btn primary", style: "padding:6px 12px;font-weight:600" %>
      <% end %>
      <% if @current %>
        <%= button_to rematch_earnings_path, method: :post,
              form: { style: "display:inline" },
              class: "btn", style: "padding:6px 12px",
              title: "Re-run the matcher with current published posts" do %>
          <%= icon :bolt, size: 13 %> Auto-match
        <% end %>
      <% end %>
    </div>
  </div>

  <% if flash[:alert] %>
    <div class="card" style="padding:10px 14px;background:var(--neg-bg);color:var(--neg);font-size:12px;margin-bottom:16px;border-color:transparent">
      <%= flash[:alert] %>
    </div>
  <% end %>
  <% if flash[:notice] %>
    <div class="card" style="padding:10px 14px;background:var(--pos-bg);color:var(--pos);font-size:12px;margin-bottom:16px;border-color:transparent">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <div class="kpi-row" style="margin-bottom:20px">
    <div class="kpi">
      <div class="kpi-label">Reported · <%= @current&.label || "—" %></div>
      <div class="kpi-value"><span class="unit">$</span><%= number_with_delimiter('%.2f' % (@kpi_reported_cents / 100.0)) %></div>
      <div class="kpi-delta up"><%= @current ? "CSV uploaded #{@current.uploaded_at&.strftime('%b %-d')}" : "no statement uploaded" %></div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Auto-matched</div>
      <div class="kpi-value"><%= '%.1f' % @kpi_match_rate %><span class="unit" style="margin-left:2px;margin-right:0">%</span></div>
      <div class="kpi-delta up"><%= @current ? "#{@current.matched_count} of #{@current.rows_count} rows" : "—" %></div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Needs review</div>
      <div class="kpi-value" style="color:<%= @kpi_needs_review.zero? ? 'var(--ink-3)' : 'var(--accent-fg)' %>"><%= @kpi_needs_review %></div>
      <div class="kpi-delta" style="color:var(--accent-fg)"><%= @kpi_needs_review.zero? ? "all reconciled" : "orphan rows" %></div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Variance</div>
      <div class="kpi-value"><span class="unit">$</span><%= '%.2f' % (@kpi_variance_cents / 100.0) %></div>
      <div class="kpi-delta" style="color:var(--ink-3)">vs. tracker</div>
    </div>
  </div>

  <% if @statements.empty? %>
    <div class="card" style="padding:32px;text-align:center;color:var(--ink-3)">
      <div class="eyebrow" style="margin-bottom:8px">No statements yet</div>
      <div style="font-size:13px">
        Upload a Temu commission CSV using the button above. We'll parse it, store every row, and try to match each commission to one of your published posts.
      </div>
    </div>
  <% else %>
    <%# Reconciliation queue %>
    <div class="card" style="padding:0;margin-bottom:20px">
      <div class="card-head">
        <div class="card-title">Reconciliation queue · <%= @current.label %></div>
        <span class="card-sub" style="margin-left:8px"><%= @kpi_needs_review %> rows · earliest <%= @reconcile_queue.first&.occurred_at&.strftime('%b %-d') || '—' %></span>
      </div>
      <% if @reconcile_queue.any? %>
        <table class="tbl">
          <thead>
            <tr>
              <th>Date</th>
              <th>Order ID (Temu)</th>
              <th>Product (CSV)</th>
              <th class="r">Commission</th>
              <th>Suggested match</th>
              <th style="width:100px"></th>
            </tr>
          </thead>
          <tbody>
            <% @reconcile_queue.each do |row| %>
              <% confidence = row.match_confidence %>
              <% suggested = row.post %>
              <tr>
                <td class="mono" style="font-size:11px;color:var(--ink-3)">
                  <%= row.occurred_at&.strftime("%b %-d %H:%M") || "—" %>
                </td>
                <td class="mono" style="font-size:11px;color:var(--ink-2)">
                  <%= truncate(row.external_order_id || "—", length: 14) %>
                </td>
                <td style="color:var(--ink);font-size:12px">
                  <%= truncate(row.raw_product_label || "—", length: 40) %>
                </td>
                <td class="num r" style="color:var(--pos);font-weight:600">
                  $<%= '%.2f' % ((row.commission_cents || 0) / 100.0) %>
                </td>
                <td>
                  <% if suggested %>
                    <div style="font-size:12px;color:var(--ink)"><%= truncate(suggested.content_angle.product.title, length: 32) %></div>
                    <div class="row" style="gap:4px;margin-top:3px">
                      <div style="width:50px;height:3px;background:var(--bg-3);border-radius:2px">
                        <div style="width:<%= confidence %>%;height:100%;background: <%= confidence >= 80 ? 'var(--pos)' : 'var(--accent)' %>;border-radius:2px"></div>
                      </div>
                      <span class="mono" style="font-size:10px;color:var(--ink-3)"><%= confidence %>% match</span>
                    </div>
                  <% else %>
                    <div style="font-size:12px;color:var(--ink-3)">— no confident match</div>
                  <% end %>
                </td>
                <td>
                  <div class="row" style="gap:4px;justify-content:flex-end">
                    <% if confidence >= 80 %>
                      <span class="tag live"><span class="dot"></span>Auto-matched</span>
                    <% else %>
                      <button class="btn sm" style="padding:3px 8px">Manual</button>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div style="padding:24px;text-align:center;color:var(--pos);font-size:13px">
          <%= icon :check, size: 14, stroke: 2.5, style: "vertical-align:-2px;margin-right:4px" %>
          Everything reconciled.
        </div>
      <% end %>
    </div>

    <%# Monthly statements %>
    <div class="card" style="padding:0">
      <div class="card-head"><div class="card-title">Monthly statements</div></div>
      <table class="tbl">
        <thead>
          <tr>
            <th>Month</th>
            <th>CSV uploaded</th>
            <th>Rows</th>
            <th class="r">Reported</th>
            <th class="r">Matched</th>
            <th class="r">Variance</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% @statements.each do |s| %>
            <tr>
              <td class="serif" style="font-style:normal;font-size:16px;color:var(--ink)"><%= s.label %></td>
              <td class="mono" style="font-size:11px;color:var(--ink-3)"><%= s.uploaded_at&.strftime('%b %-d') || '—' %></td>
              <td class="mono"><%= s.rows_count %></td>
              <td class="num r" style="color:var(--ink)">$<%= '%.2f' % ((s.total_reported_cents || 0) / 100.0) %></td>
              <td class="num r" style="color:var(--ink-2)"><%= s.matched_count %> / <%= s.rows_count %></td>
              <td class="num r" style="color: <%= s.variance_cents.zero? ? 'var(--ink-3)' : 'var(--accent-fg)' %>">
                <%= s.variance_cents.zero? ? "—" : "$#{'%.2f' % (s.variance_cents.abs / 100.0)}" %>
              </td>
              <td>
                <% if s.reconciled? %>
                  <span class="tag live"><span class="dot"></span>Reconciled</span>
                <% elsif s.uploaded? %>
                  <span class="tag scheduled">Pending match</span>
                <% elsif s.processing? %>
                  <span class="tag scheduled">Processing</span>
                <% else %>
                  <span class="tag warn">Errored</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>
