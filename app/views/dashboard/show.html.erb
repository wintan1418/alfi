<% content_for :active_nav, "dashboard" %>
<% content_for :title, "Dashboard" %>
<% @crumbs = ["alfi", "Dashboard"] %>

<%
  # Real KPIs computed in the controller; sparklines stay sample-shaped until
  # we have enough real time-series to draw from.
  kpis = {
    earnings_mtd: @kpi_earnings_mtd,
    earnings_delta: "+18.4%",
    earnings_spark: [820, 870, 910, 940, 1010, 1040, 1090, 1140, 1190, 1240, @kpi_earnings_mtd.to_i],
    clicks_today: @kpi_clicks_today,
    clicks_delta: @kpi_clicks_today > 0 ? "+#{@kpi_clicks_today} today" : "—",
    clicks_spark: [120, 180, 90, 200, 240, 170, 280, 320, 290, 340, [@kpi_clicks_today, 380].max],
    ctr: 4.82,
    ctr_delta: "+0.31",
    ctr_spark: [3.8, 4.0, 4.1, 4.2, 4.3, 4.4, 4.4, 4.5, 4.6, 4.7, 4.82],
    posted: @kpi_posts_week,
    posted_delta: "+#{@kpi_posts_week}",
    posted_spark: [2, 3, 5, 4, 6, 5, 7, 8, 6, 7, [@kpi_posts_week, 4].max]
  }

  feed = [
    { t: "11:42:18", product: "Magnetic Cable Organizer", platform: "pin", tone: "practical", country: "US",  earned: 0.31 },
    { t: "11:41:55", product: "Adjustable Laptop Stand",  platform: "tg",  tone: "witty",     country: "CA",  earned: 0.42 },
    { t: "11:41:12", product: "Magnetic Cable Organizer", platform: "pin", tone: "practical", country: "UK",  earned: 0.28 },
    { t: "11:40:47", product: "Self-Stirring Mug",        platform: "tg",  tone: "witty",     country: "US",  earned: 0.18 },
    { t: "11:40:20", product: "Foldable Travel Hairdryer", platform: "x",  tone: "practical", country: "AU",  earned: 0.35 },
    { t: "11:39:58", product: "Magnetic Cable Organizer", platform: "tg",  tone: "witty",     country: "US",  earned: 0.31 },
    { t: "11:39:14", product: "Silicone Stretch Lids",    platform: "pin", tone: "practical", country: "US",  earned: 0.22 }
  ]

  short = { "telegram" => "tg", "pinterest" => "pin", "x" => "x", "tiktok" => "tt", "instagram" => "ig" }
  schedule = (@today_schedule || []).map do |post|
    time = post.published_at || post.scheduled_at
    {
      when_at: time&.in_time_zone&.strftime("%H:%M") || "—",
      product: post.content_angle&.product&.title || "Post",
      platform: short[post.platform.to_s] || post.platform.to_s,
      tone: post.content_angle&.tone,
      status: post.published? ? :live : (post.failed? ? :failed : :scheduled),
      hot: post.content_angle&.product&.flagged?
    }
  end
%>

<div class="page">
  <%# Header %>
  <div class="spread" style="margin-bottom:22px">
    <div>
      <h1 class="section-h">Good morning, Pastro.</h1>
      <div class="section-sub">
        <span class="mono"><%= @products.count %> product cards</span> waiting for review · last sync <span class="mono">2 min ago</span>
      </div>
    </div>
    <div class="row" style="gap:8px">
      <button class="btn"><%= icon :refresh, size: 13 %> Sync Temu</button>
      <%= link_to new_product_path, class: "btn accent" do %>
        <%= icon :plus, size: 13, stroke: 2.2 %> Add product
      <% end %>
    </div>
  </div>

  <%# KPI strip %>
  <div class="kpi-row" style="margin-bottom:24px">
    <div class="kpi">
      <div class="kpi-label">Earnings · MTD</div>
      <div class="kpi-value"><span class="unit">$</span><%= number_with_delimiter("%.2f" % kpis[:earnings_mtd]) %></div>
      <div class="kpi-delta up"><%= icon :arrow_up, size: 11, stroke: 2 %><%= kpis[:earnings_delta] %></div>
      <div class="kpi-spark"><%= sparkline kpis[:earnings_spark], color: "var(--pos)", width: 140 %></div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Clicks · Today</div>
      <div class="kpi-value"><%= mono_n kpis[:clicks_today] %></div>
      <div class="kpi-delta up"><%= icon :arrow_up, size: 11, stroke: 2 %><%= kpis[:clicks_delta] %></div>
      <div class="kpi-spark"><%= sparkline kpis[:clicks_spark], color: "var(--accent)", width: 140 %></div>
    </div>
    <div class="kpi">
      <div class="kpi-label">CTR · 7-day</div>
      <div class="kpi-value"><%= "%.2f" % kpis[:ctr] %><span class="unit" style="margin-left:2px;margin-right:0">%</span></div>
      <div class="kpi-delta up"><%= icon :arrow_up, size: 11, stroke: 2 %><%= kpis[:ctr_delta] %></div>
      <div class="kpi-spark"><%= sparkline kpis[:ctr_spark], color: "var(--pos)", width: 140 %></div>
    </div>
    <div class="kpi">
      <div class="kpi-label">Posts · This week</div>
      <div class="kpi-value"><%= kpis[:posted] %></div>
      <div class="kpi-delta up"><%= icon :arrow_up, size: 11, stroke: 2 %><%= kpis[:posted_delta] %></div>
      <div class="kpi-spark"><%= sparkline kpis[:posted_spark], color: "var(--info)", width: 140 %></div>
    </div>
  </div>

  <%# Two-column grid: Review queue + Live click feed %>
  <div style="display:grid;grid-template-columns:1.6fr 1fr;gap:20px">
    <div class="card">
      <div class="card-head">
        <div>
          <div class="card-title">Review queue</div>
          <div class="card-sub" style="margin-top:2px"><%= @products.size %> products · 156 angles waiting</div>
        </div>
        <div class="row" style="margin-left:auto;gap:6px">
          <button class="btn sm ghost"><%= icon :filter, size: 11 %> Filter</button>
          <%= link_to products_path, class: "btn sm" do %>
            View all <%= icon :arrow_right, size: 11 %>
          <% end %>
        </div>
      </div>
      <div>
        <% @products.each_with_index do |p, i| %>
          <%= render "shared/product_row", product: p, first: i.zero? %>
        <% end %>
      </div>
    </div>

    <div class="card">
      <div class="card-head">
        <div>
          <div class="card-title">Live click feed</div>
          <div class="card-sub" style="margin-top:2px">
            <span style="color:var(--pos);display:inline-flex;align-items:center;gap:4px">
              <span class="dot-pulse" style="width:5px;height:5px;border-radius:50%;background:var(--pos);display:inline-block"></span>
              Streaming
            </span>
          </div>
        </div>
      </div>
      <div style="padding:4px 0;max-height:380px;overflow-y:auto">
        <% feed.each_with_index do |f, i| %>
          <div style="padding:9px 16px;<%= 'border-bottom:1px solid var(--line)' unless i == feed.size - 1 %>">
            <div class="spread">
              <div class="mono" style="font-size:10px;color:var(--ink-3)"><%= f[:t] %></div>
              <div class="mono" style="font-size:11px;color:var(--pos);font-weight:600">+$<%= "%.2f" % f[:earned] %></div>
            </div>
            <div style="font-size:12px;color:var(--ink);margin:3px 0;font-weight:500"><%= f[:product] %></div>
            <div class="row" style="gap:8px;font-size:11px">
              <%= platform_pill f[:platform] %>
              <span class="mono" style="color:var(--ink-3)"><%= f[:tone] %></span>
              <span class="mono" style="color:var(--ink-3);margin-left:auto"><%= f[:country] %></span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <%# Second row: Top performers + Schedule %>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;margin-top:20px">
    <div class="card">
      <div class="card-head">
        <div class="card-title">Top performers · MTD</div>
        <div class="row" style="margin-left:auto;gap:6px">
          <%= link_to analytics_path, class: "btn sm ghost" do %>
            Open analytics <%= icon :arrow_right, size: 11 %>
          <% end %>
        </div>
      </div>
      <table class="tbl">
        <thead>
          <tr>
            <th style="width:28px">#</th>
            <th>Product</th>
            <th class="r">Clicks</th>
            <th class="r">Earned</th>
            <th style="width:80px">Best ch.</th>
          </tr>
        </thead>
        <tbody>
          <% @top_products.each_with_index do |p, i| %>
            <tr onclick="window.location='<%= product_path(p) %>'" style="cursor:pointer">
              <td class="mono" style="color:var(--ink-3);font-size:11px"><%= "%02d" % (i + 1) %></td>
              <td>
                <div style="color:var(--ink);font-weight:500;font-size:12px"><%= p.title %></div>
                <div class="mono" style="font-size:10px;color:var(--ink-3)"><%= p.legacy_id %></div>
              </td>
              <td class="num r" style="color:var(--ink)"><%= mono_n p.click_count %></td>
              <td class="num r" style="color:var(--pos);font-weight:600"><%= usd p.earned_amount %></td>
              <td><%= platform_pill ([ "pin", "tg", "x" ][i % 3]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <div class="card">
      <div class="card-head">
        <div class="card-title">Today's schedule</div>
        <% live_n = schedule.count { |s| s[:status] == :live } %>
        <% queued_n = schedule.count { |s| s[:status] == :scheduled } %>
        <div class="card-sub" style="margin-left:auto">
          <span style="color:var(--pos)"><%= live_n %> live</span> · <span style="color:var(--info)"><%= queued_n %> queued</span>
        </div>
      </div>
      <div style="padding:4px 0">
        <% if schedule.empty? %>
          <div style="padding:24px 16px;text-align:center;color:var(--ink-3);font-size:12px">
            Nothing scheduled today. <%= link_to "Add a product", new_product_path, style: "color:var(--accent-fg)" %>.
          </div>
        <% else %>
          <% schedule.each_with_index do |post, i| %>
            <div class="row" style="padding:10px 16px;<%= 'border-bottom:1px solid var(--line)' unless i == schedule.size - 1 %>">
              <div class="mono" style="font-size:11px;color:var(--ink-3);width:56px"><%= post[:when_at] %></div>
              <%= platform_pill post[:platform] %>
              <div style="flex:1;font-size:12px;color:var(--ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap">
                <%= truncate(post[:product], length: 32) %>
                <span class="mono" style="font-size:10px;color:var(--ink-3);margin-left:6px">· <%= post[:tone] %></span>
              </div>
              <%= status_tag post[:status] %>
              <% if post[:hot] %>
                <span class="tag flagged"><%= icon :bolt, size: 9, stroke: 2.2 %> Hot</span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
