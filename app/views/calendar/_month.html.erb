<%
  days  = %w[Mon Tue Wed Thu Fri Sat Sun]
  short = { "telegram" => "tg", "pinterest" => "pin", "x" => "x", "tiktok" => "tt", "instagram" => "ig" }

  weeks = []
  cursor = @grid_start
  while cursor <= @grid_end
    weeks << (0..6).map { |i| cursor + i.days }
    cursor += 7.days
  end
%>

<div class="card" style="padding:0;overflow:hidden">
  <%# Day-of-week headers %>
  <div style="display:grid;grid-template-columns:repeat(7, 1fr);border-bottom:1px solid var(--line);background:var(--bg-2)">
    <% days.each_with_index do |d, i| %>
      <div class="eyebrow" style="padding:10px 12px;<%= 'border-left:1px solid var(--line);' if i > 0 %>"><%= d %></div>
    <% end %>
  </div>

  <%# Week rows %>
  <% weeks.each_with_index do |week, w_idx| %>
    <div style="display:grid;grid-template-columns:repeat(7, 1fr);<%= 'border-bottom:1px solid var(--line)' unless w_idx == weeks.size - 1 %>">
      <% week.each_with_index do |date, d_idx| %>
        <%
          posts_today = @month_grid[date] || []
          is_today = date == Date.current
          in_month = (date.month == @month_start.month)
          dim = !in_month
        %>
        <div style="
          min-height:110px;padding:8px;position:relative;
          <%= 'border-left:1px solid var(--line);' if d_idx > 0 %>
          <%= 'background:var(--accent-bg);' if is_today %>
          <%= 'background:var(--bg-2);' if dim %>">
          <div class="row" style="gap:6px;margin-bottom:6px">
            <%= link_to calendar_path(view: "week", date: date.iso8601),
                  class: "serif",
                  style: "font-style:normal;font-size:18px;text-decoration:none;color: #{is_today ? 'var(--accent-fg)' : (dim ? 'var(--ink-4)' : 'var(--ink)')}" do %>
              <%= date.day %>
            <% end %>
            <% if posts_today.any? %>
              <span class="mono" style="font-size:9px;color: <%= dim ? 'var(--ink-4)' : 'var(--ink-3)' %>;margin-left:auto">
                <%= posts_today.size %>
              </span>
            <% end %>
          </div>

          <% posts_today.first(3).each do |post| %>
            <%
              short_key = short[post.platform.to_s] || post.platform.to_s
              product = post.content_angle&.product
              title = product ? truncate(product.title, length: 14) : (post.content_angle&.hook || "Post")
              is_live = post.published?
            %>
            <%= link_to product ? product_path(product) : "#",
                  style: "
                    display:block;text-decoration:none;
                    background: #{is_live ? 'var(--accent-bg)' : 'var(--surface)'};
                    border:1px solid var(--line);
                    border-left:3px solid var(--#{short_key});
                    border-radius:3px;padding:2px 5px;margin-bottom:2px;font-size:10px;
                    overflow:hidden;text-overflow:ellipsis;white-space:nowrap;
                    color:var(--ink)" do %>
              <span style="font-weight:500"><%= title %></span>
            <% end %>
          <% end %>

          <% if posts_today.size > 3 %>
            <%= link_to calendar_path(view: "week", date: date.iso8601),
                  class: "mono",
                  style: "font-size:10px;color:var(--ink-3);text-decoration:none;display:block;margin-top:2px" do %>
              + <%= posts_today.size - 3 %> more →
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
