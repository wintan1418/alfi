<% content_for :standalone, true %>
<% content_for :title, "alfi — affiliate automation" %>

<div style="min-height:100vh;background:var(--bg);display:flex;flex-direction:column">

  <header style="padding:18px 32px;display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid var(--line)">
    <%= link_to root_path, class: "row", style: "gap:10px;text-decoration:none" do %>
      <span class="sb-brand-mark" style="width:26px;height:26px;font-size:13px">α</span>
      <span class="serif" style="font-size:22px;color:var(--ink)">alfi</span>
    <% end %>
    <div class="row" style="gap:8px">
      <%= link_to "Open dashboard", dashboard_path, class: "btn sm ghost" %>
      <%= link_to "Sign in", new_session_path, class: "btn sm primary" %>
    </div>
  </header>

  <main style="flex:1;display:flex;align-items:center;justify-content:center;padding:64px 24px">
    <div style="max-width:760px;text-align:center">
      <div class="eyebrow" style="margin-bottom:18px;display:flex;justify-content:center;gap:8px;align-items:center">
        <span style="width:6px;height:6px;border-radius:50%;background:var(--accent)"></span>
        affiliate automation · solo operator
      </div>

      <h1 class="serif" style="font-size:64px;line-height:0.95;letter-spacing:-0.02em;color:var(--ink);margin:0 0 22px;font-style:normal">
        Paste a product URL.<br>
        <em>Ship five posts.</em>
      </h1>

      <p style="font-size:17px;line-height:1.55;color:var(--ink-2);max-width:580px;margin:0 auto 32px">
        alfi takes a Temu link, writes copy in three tones across five platforms, then tracks every click home. One dashboard, built for one operator.
      </p>

      <div class="row" style="gap:10px;justify-content:center">
        <%= link_to dashboard_path, class: "btn accent", style: "padding:11px 20px;font-size:14px;font-weight:600" do %>
          Open the workshop <%= icon :arrow_right, size: 13 %>
        <% end %>
        <%= link_to "Sign in", new_session_path, class: "btn", style: "padding:11px 20px;font-size:14px" %>
      </div>

      <div class="mono" style="margin-top:36px;font-size:11px;color:var(--ink-3)">
        Telegram · Pinterest · X · TikTok · Instagram
      </div>
    </div>
  </main>

  <section style="padding:64px 32px;border-top:1px solid var(--line);background:var(--bg-2)">
    <div style="max-width:1100px;margin:0 auto">
      <div class="eyebrow" style="text-align:center;margin-bottom:32px">how it works</div>
      <div style="display:grid;grid-template-columns:repeat(3, 1fr);gap:28px">
        <div class="card" style="padding:22px;background:var(--surface)">
          <div class="mono" style="font-size:11px;color:var(--accent-fg);background:var(--accent-bg);padding:2px 8px;border-radius:4px;display:inline-block;margin-bottom:14px">01</div>
          <h3 class="serif" style="font-size:24px;font-style:normal;margin:0 0 10px;letter-spacing:-0.01em">Pick the angle.</h3>
          <p style="font-size:13px;line-height:1.6;color:var(--ink-3);margin:0">
            Practical, Premium, Witty — three tones per platform, fifteen angles per product. AI drafts; you decide which one ships.
          </p>
        </div>
        <div class="card" style="padding:22px;background:var(--surface)">
          <div class="mono" style="font-size:11px;color:var(--accent-fg);background:var(--accent-bg);padding:2px 8px;border-radius:4px;display:inline-block;margin-bottom:14px">02</div>
          <h3 class="serif" style="font-size:24px;font-style:normal;margin:0 0 10px;letter-spacing:-0.01em">Ship to every channel.</h3>
          <p style="font-size:13px;line-height:1.6;color:var(--ink-3);margin:0">
            Native-formatted previews — Telegram bubble, Pinterest pin, X tweet — so you know exactly how each post lands before it goes live.
          </p>
        </div>
        <div class="card" style="padding:22px;background:var(--surface)">
          <div class="mono" style="font-size:11px;color:var(--accent-fg);background:var(--accent-bg);padding:2px 8px;border-radius:4px;display:inline-block;margin-bottom:14px">03</div>
          <h3 class="serif" style="font-size:24px;font-style:normal;margin:0 0 10px;letter-spacing:-0.01em">Track every click.</h3>
          <p style="font-size:13px;line-height:1.6;color:var(--ink-3);margin:0">
            Bot-filtered short links, per-tone EPC, reconciled against Temu's monthly CSV. Know which angle is actually earning.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section style="padding:56px 32px;border-top:1px solid var(--line)">
    <div style="max-width:920px;margin:0 auto;text-align:center">
      <h2 class="serif" style="font-size:32px;font-style:italic;letter-spacing:-0.02em;margin:0 0 14px">A quiet desk for the operator who ships.</h2>
      <p style="font-size:14px;color:var(--ink-3);max-width:560px;margin:0 auto 24px">
        Not multi-tenant SaaS. Not a community tool. Just one operator, one channel of attention, one place that tells the truth about what's working.
      </p>
      <%= link_to dashboard_path, class: "btn accent", style: "padding:11px 20px;font-size:14px;font-weight:600" do %>
        Take a look <%= icon :arrow_right, size: 13 %>
      <% end %>
    </div>
  </section>

  <footer style="padding:22px 32px;text-align:center;color:var(--ink-3);font-size:11px;border-top:1px solid var(--line);background:var(--bg-2)">
    <span class="mono">alfi</span> · built for ones who ship · 2026
  </footer>
</div>
