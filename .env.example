# Copy to .env in development. Never commit .env.
# In production these come from Kamal secrets, not this file.

# ---- Database ----
# In dev, omit DATABASE_URL and Rails will use config/database.yml defaults.
# DATABASE_URL=postgres://localhost/affiliate_development

# ---- Cloudflare R2 (image hosting) ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=pacearena-products
R2_PUBLIC_URL=https://media.example.com

# ---- AI: Anthropic ----
ANTHROPIC_API_KEY=

# ---- Apify (Temu product scraper) ----
APIFY_API_TOKEN=
APIFY_TEMU_ACTOR_ID=piotrv1001~temu-listings-scraper

# ---- Piloterr (alternative Temu single-product API) ----
PILOTERR_API_KEY=

# ---- Telegram (bot token shared; chat_id stored per ChannelAccount) ----
TELEGRAM_BOT_TOKEN=

# ---- Pinterest ----
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=https://example.com/oauth/pinterest/callback

# ---- X / Twitter (deferred — only set when X integration is enabled) ----
X_API_KEY=
X_API_SECRET=
X_CLIENT_ID=
X_CLIENT_SECRET=

# ---- MaxMind GeoIP (download GeoLite2-City.mmdb to db/) ----
MAXMIND_DB_PATH=db/GeoLite2-City.mmdb

# ---- Short-link host (used to build outbound /r/:slug URLs) ----
SHORT_LINK_HOST=https://example.com
